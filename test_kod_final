def buduj_skonsolidowany_harmonogram(zadania_miast):
    kurierzy = []

    while any(len(zadania_miast[m]) > 0 for m in zadania_miast):
        id_kuriera = len(kurierzy) + 1

        # Start dokładnie o 08:00
        obecny_czas_min = 0.0
        paliwo_suma_l = 0.0
        dystans_suma_km = 0.0
        logi = []
        przerwa_odbyta = False

        logi.append(
            f"[{formatuj_godzine(obecny_czas_min)}] Przybycie kuriera do bazy. Pobranie gotowego, załadowanego pojazdu (5 min).")
        obecny_czas_min += 5.0

        aktualna_waga_busa = 0.0
        aktualna_obj_busa = 0.0
        paczki_w_pojeździe = 0

        stat_paczki_lacznie = 0
        stat_waga_lacznie = 0.0

        obecna_pozycja = "ZG"
        kierowca_pracuje = True

        while kierowca_pracuje:
            sekwencja_miast = pobierz_płaską_liste_punktów(zadania_miast)
            if not sekwencja_miast:
                break

            znaleziono_zadanie = False

            for kod_miasta in sekwencja_miast:
                krawedz_dojazd = pobierz_krawedz(obecna_pozycja, kod_miasta) if obecna_pozycja != kod_miasta else None
                czas_dojazdu = oblicz_czas_przejazdu(krawedz_dojazd) if krawedz_dojazd else 0.0

                paczki_do_wyjęcia = []
                waga_punktu = 0.0
                obj_punktu = 0.0
                paczkomaty_punktu = []

                for p_id, p_lista in list(zadania_miast[kod_miasta].items()):
                    w = sum(float(p['waga_kg']) for p in p_lista)
                    o = sum(
                        float(p['wysokosc_cm']) * float(p['szerokosc_cm']) * float(p['dlugosc_cm']) for p in p_lista)

                    if (aktualna_waga_busa + waga_punktu + w <= LIMIT_WAGI_KG) and \
                            (aktualna_obj_busa + obj_punktu + o <= LIMIT_OBJETOSCI_CM3):
                        paczki_do_wyjęcia.extend(p_lista)
                        waga_punktu += w
                        obj_punktu += o
                        paczkomaty_punktu.append(p_id)

                # --- POWRÓT REJSOWY NA BAZĘ W TRAKCIE DNIA (KURIER WRACA PO DRUGĄ TURĘ) ---
                if not paczki_do_wyjęcia:
                    if obecna_pozycja != "ZG":
                        krawedz_powrot = pobierz_krawedz(obecna_pozycja, "ZG")
                        czas_p = oblicz_czas_przejazdu(krawedz_powrot)

                        # Czy starczy czasu na powrót liniowy + zjazd techniczny 10 min + załadunek dnia 20 min?
                        if obecny_czas_min + czas_p + CZAS_ZJAZDU_MID_MIN + CZAS_ZALADUNKU_MID_MIN <= MAKS_CZAS_ZMIANY_MIN:
                            start_powrotu = obecny_czas_min
                            obecny_czas_min += czas_p
                            logi.append(
                                f"[{formatuj_godzine(start_powrotu)} - {formatuj_godzine(obecny_czas_min)}] Powrót techniczny z trasy do ZG | Dystans: {krawedz_powrot['km']} km")

                            p_l, _ = oblicz_spalanie_trasa(krawedz_powrot, aktualna_waga_busa)
                            paliwo_suma_l += p_l
                            dystans_suma_km += krawedz_powrot["km"]

                            start_zjazdu = obecny_czas_min
                            obecny_czas_min += CZAS_ZJAZDU_MID_MIN
                            logi.append(
                                f"[{formatuj_godzine(start_zjazdu)} - {formatuj_godzine(obecny_czas_min)}] Wjazd pod rampę magazynu (+10 min zjazd)")
                            obecna_pozycja = "ZG"
                        else:
                            kierowca_pracuje = False
                            break
                    else:
                        # Jeśli kończył w ZG i potrzebuje między-załadunku
                        if obecny_czas_min + CZAS_ZJAZDU_MID_MIN + CZAS_ZALADUNKU_MID_MIN <= MAKS_CZAS_ZMIANY_MIN:
                            start_zjazdu = obecny_czas_min
                            obecny_czas_min += CZAS_ZJAZDU_MID_MIN
                            logi.append(
                                f"[{formatuj_godzine(start_zjazdu)} - {formatuj_godzine(obecny_czas_min)}] Zjazd z rejonu ZG pod rampę na przeładunek (+10 min zjazd)")
                        else:
                            kierowca_pracuje = False
                            break

                    # Załadunek w środku dnia (wtedy kurier traci 20 minut pracy)
                    start_zaladunku = obecny_czas_min
                    logi.append(
                        f"[{formatuj_godzine(start_zaladunku)}] Oczekiwanie na doładowanie busa w trakcie dnia.")

                    if not przerwa_odbyta and (120.0 <= obecny_czas_min <= 360.0):
                        logi.append(
                            f"    * [{formatuj_godzine(obecny_czas_min)}] pracownik wzial 20 min przerwy (w trakcie trwania załadunku)")
                        przerwa_odbyta = True

                    obecny_czas_min += CZAS_ZALADUNKU_MID_MIN

                    aktualna_waga_busa = 0.0
                    aktualna_obj_busa = 0.0
                    paczki_w_pojeździe = 0
                    znaleziono_zadanie = True
                    break

                # Kalkulacja czasowa dla obsługi miast
                czas_operacji, paliwo_m, dystans_m = oblicz_operacje_miejskie(kod_miasta, len(paczkomaty_punktu),
                                                                              len(paczki_do_wyjęcia),
                                                                              (aktualna_waga_busa + waga_punktu))

                # Zjazd ostateczny kosztuje na koniec dnia tylko 5 minut zdania dokumentów + ewentualny dolot liniowy
                czas_zjazdu_koncowego = CZAS_ZDANIA_PAPIEROW_MIN if kod_miasta == "ZG" else (
                            oblicz_czas_przejazdu(pobierz_krawedz(kod_miasta, "ZG")) + CZAS_ZDANIA_PAPIEROW_MIN)

                czas_potencjalnej_przerwy = CZAS_PRZERWY_MIN if (
                            not przerwa_odbyta and (120.0 <= (obecny_czas_min + czas_dojazdu) <= 360.0)) else 0.0
                total_czas_operacji = obecny_czas_min + czas_dojazdu + czas_operacji + czas_potencjalnej_przerwy + czas_zjazdu_koncowego

                if total_czas_operacji <= MAKS_CZAS_ZMIANY_MIN:
                    if krawedz_dojazd:
                        start_dojazdu = obecny_czas_min
                        obecny_czas_min += czas_dojazdu
                        p_l, _ = oblicz_spalanie_trasa(krawedz_dojazd, aktualna_waga_busa + waga_punktu)
                        paliwo_suma_l += p_l
                        dystans_suma_km += krawedz_dojazd["km"]
                        logi.append(
                            f"[{formatuj_godzine(start_dojazdu)} - {formatuj_godzine(obecny_czas_min)}] Wyjazd. Dojazd relacji: {obecna_pozycja} -> {kod_miasta} | {krawedz_dojazd['km']} km")
                    else:
                        obecny_czas_min += czas_dojazdu

                    # Okno przerwy pracowniczej (10:00 - 14:00)
                    if not przerwa_odbyta and (120.0 <= obecny_czas_min <= 360.0):
                        logi.append(f"    * [{formatuj_godzine(obecny_czas_min)}] pracownik wzial 20 min przerwy")
                        obecny_czas_min += CZAS_PRZERWY_MIN
                        przerwa_odbyta = True

                    start_dostaw = obecny_czas_min
                    obecny_czas_min += czas_operacji
                    logi.append(
                        f"[{formatuj_godzine(start_dostaw)} - {formatuj_godzine(obecny_czas_min)}] Rozwóz paczek, sektor: {dane_miast_miejskie[kod_miasta]['name']} | Doręczono: {len(paczki_do_wyjęcia)} paczek")

                    paliwo_suma_l += paliwo_m
                    dystans_suma_km += dystans_m

                    aktualna_waga_busa += waga_punktu
                    aktualna_obj_busa += obj_punktu
                    paczki_w_pojeździe += len(paczki_do_wyjęcia)

                    stat_paczki_lacznie += len(paczki_do_wyjęcia)
                    stat_waga_lacznie += waga_punktu

                    for p_id in paczkomaty_punktu:
                        del zadania_miast[kod_miasta][p_id]
                    if len(zadania_miast[kod_miasta]) == 0:
                        del zadania_miast[kod_miasta]

                    obecna_pozycja = kod_miasta
                    znaleziono_zadanie = True
                    break
                else:
                    continue

            if not znaleziono_zadanie:
                kierowca_pracuje = False

        # --- FINAŁ PRACY KURIERA (ZDAJE AUTO I DO DOMU) ---
        if obecna_pozycja != "ZG":
            krawedz_powrot = pobierz_krawedz(obecna_pozycja, "ZG")
            if krawedz_powrot:
                start_powrotu = obecny_czas_min
                obecny_czas_min += oblicz_czas_przejazdu(krawedz_powrot)
                logi.append(
                    f"[{formatuj_godzine(start_powrotu)} - {formatuj_godzine(obecny_czas_min)}] Powrót liniowy z rejonu końcowego do bazy w Zielonej Górze | Przebieg: {krawedz_powrot['km']} km")

                p_l, _ = oblicz_spalanie_trasa(krawedz_powrot, waga_ladunku_kg=0.0)
                paliwo_suma_l += p_l
                dystans_suma_km += krawedz_powrot["km"]

                start_zdania = obecny_czas_min
                obecny_czas_min += CZAS_ZDANIA_PAPIEROW_MIN
                logi.append(
                    f"[{formatuj_godzine(start_zdania)} - {formatuj_godzine(obecny_czas_min)}] Zdanie dokumentacji i pojazdu na bazie (+5 min rozliczenie końcowe). Załadunek nocny robi firma.")
        else:
            # Gdy kurier skończył ostatnie paczki w ZG, jedzie wprost zdać dokumenty
            start_zdania = obecny_czas_min
            obecny_czas_min += CZAS_ZDANIA_PAPIEROW_MIN
            logi.append(
                f"[{formatuj_godzine(start_zdania)} - {formatuj_godzine(obecny_czas_min)}] Zdanie dokumentacji i pojazdu na bazie po rejonie ZG (+5 min rozliczenie końcowe). Załadunek nocny robi firma.")

        # Jeśli jakimś cudem nie wpadła przerwa w ciągu dnia
        if not przerwa_odbyta:
            logi.append(f"    * [{formatuj_godzine(obecny_czas_min)}] pracownik wzial 20 min przerwy")
            obecny_czas_min += CZAS_PRZERWY_MIN

        logi.append(f"[{formatuj_godzine(obecny_czas_min)}] Kurier opuszcza bazę. Koniec zmiany.")

        kurierzy.append({
            "id": id_kuriera,
            "paczki": stat_paczki_lacznie,
            "waga": stat_waga_lacznie,
            "podsumowanie": {
                "dystans_km": round(dystans_suma_km, 2),
                "czas_h": round(obecny_czas_min / 60.0, 2),
                "koszt_paliwa_pln": round(paliwo_suma_l * CENA_PALIWA_PLN_L, 2),
                "logi": logi
            }
        })

    return kurierzy


