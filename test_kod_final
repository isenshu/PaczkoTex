# MODUŁ KONTROLI I URUCHOMIENIA PLIKU CSV
# =====================================================================

def uruchom_optymalizacje_kosztowa():
    root = tk.Tk();
    root.withdraw()
    sciezka_csv = filedialog.askopenfilename(
        title="Wybierz plik CSV", filetypes=[("Pliki CSV", "*.csv")]
    )
    if not sciezka_csv: return

    paczki_per_data = defaultdict(list)
    with open(sciezka_csv, mode='r', encoding='utf-8') as plik:
        reader = csv.DictReader(plik)
        for wiersz in reader:
            paczki_per_data[wiersz['data_dostawy']].append(wiersz)

    for data, paczki in sorted(paczki_per_data.items()):
        paczki_per_miasto = defaultdict(list)
        for p in paczki:
            kod = MAPOWANIE_MIAST.get(p['miasto_docelowe'])
            if kod: paczki_per_miasto[kod].append(p)

        struktura_zadania = {}
        for kod, lista in paczki_per_miasto.items():
            paczkomaty_paczki = defaultdict(list)
            for p in lista:
                paczkomaty_paczki[p['id_paczkomatu']].append(p)
            struktura_zadania[kod] = paczkomaty_paczki

        print(f"\n==========================================================================================")
        print(f"   REJESTR KARTY DROGOWEJ FLOTY KURIERSKIEJ DLA DNIA: {data}")
        print(f"==========================================================================================")

        wynikowe_kadry = buduj_skonsolidowany_harmonogram(struktura_zadania)

        for k in wynikowe_kadry:
            p = k["podsumowanie"]
            print(f"\n KURIER {k['id']} | Paczki: {k['paczki']} szt. | Masa: {k['waga']:.1f} kg")
            print(f"   Karta drogowa (Chronologia zmianowa):")
            for linia in p["logi"]:
                print(f"        - {linia}")
            print(
                f"   WYNIK AUTA: Przebieg {p['dystans_km']} km | Łączny czas pracy kuriera: {p['czas_h']} h / 8.0 h | Paliwo: {p['koszt_paliwa_pln']} PLN")
            print("-" * 120)


if __name__ == "__main__":
    uruchom_optymalizacje_kosztowa()
